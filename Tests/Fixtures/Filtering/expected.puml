@startuml
hide empty members
class "AuditLog" as AuditLog <<struct>> <<public>> {
    +message : String
}
interface "Identifiable" as Identifiable <<protocol>> <<public>> {
    +id : UUID
}
class "Team" as Team <<class>> <<open>> {
    +members : [User]
    +audit : AuditLog
    +refresh()
}
class "User" as User <<struct>> <<public>> {
    +id : UUID
    +display() : String
}
Team o-- User : members
Identifiable <|.. User
@enduml
