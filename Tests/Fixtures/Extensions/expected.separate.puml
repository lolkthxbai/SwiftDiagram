@startuml
hide empty members
interface "Codable" as Codable <<protocol>> {
}
class "Profile" as Profile <<struct>> {
}
class "Team" as Team <<struct>> {
    users : [User]
}
class "User" as User <<struct>> {
    profile : Profile
